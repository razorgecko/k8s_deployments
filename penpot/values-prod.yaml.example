# Databases, Secrets, Ingress and oauth2-proxy are owned by kustomize owns.
fullnameOverride: "penpot"

config:
  publicUri: "https://<penpot.example.com>"

  flags: "disable-login-with-password disable-email-verification enable-oidc-registration enable-login-with-oidc"

  # base/penpot/secret.yaml
  existingSecret: "penpot-secret"
  secretKeys:
    apiSecretKey: "PENPOT_SECRET_KEY"

  telemetryEnabled: false

  # base/postgres
  postgresql:
    host: "postgres.penpot.svc.cluster.local"
    port: 5432
    database: "penpot"
    username: "penpot"
    existingSecret: "postgres-secret"
    secretKeys:
      passwordKey: "POSTGRES_PASSWORD"

  # base/valkey
  redis:
    host: "valkey.penpot.svc.cluster.local"
    port: 6379
    database: "0"

  objectsStorage:
    storageBackend: "fs"

  providers:
    existingSecret: "penpot-secret"
    secretKeys:
      oidcClientSecretKey: "OIDC_CLIENT_SECRET"
    oidc:
      enabled: true
      # The trailing slash is required, without it Penpot treats the
      # realm segment as a file name and replaces.
      baseURI: "https://<auth.example.com>/realms/<realm>/"
      clientID: "penpot"
      scopes: "openid profile email"
      roles: ""

persistence:
  assets:
    enabled: true
    storageClass: "local-path"
    size: 10Gi

ingress:
  enabled: false
