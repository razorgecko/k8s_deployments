OAUTH2_PROXY_PROVIDER=oidc
OAUTH2_PROXY_PROVIDER_DISPLAY_NAME=<Provider>
OAUTH2_PROXY_OIDC_ISSUER_URL=https://<oauth.example.com>/realms/<realm>
OAUTH2_PROXY_CLIENT_ID=oauth2-proxy
OAUTH2_PROXY_REDIRECT_URL=https://<domain.example.com>/oauth2/callback
OAUTH2_PROXY_EMAIL_DOMAINS=*
OAUTH2_PROXY_ALLOWED_GROUPS=<groups>
OAUTH2_PROXY_HTTP_ADDRESS=0.0.0.0:4180
OAUTH2_PROXY_REVERSE_PROXY=true
OAUTH2_PROXY_COOKIE_SECURE=true
OAUTH2_PROXY_WHITELIST_DOMAINS=<domain.example.com>,<oauth.example.com>
OAUTH2_PROXY_SKIP_PROVIDER_BUTTON=true
OAUTH2_PROXY_CODE_CHALLENGE_METHOD=S256
# Reverse-proxy mode: oauth2-proxy proxies every non-/oauth2 request
OAUTH2_PROXY_UPSTREAMS=http://open-webui.open-webui.svc.cluster.local:8080
OAUTH2_PROXY_PASS_USER_HEADERS=false
# Allow native auth (Bearer) for API endpoints
OAUTH2_PROXY_SKIP_AUTH_ROUTES=GET=^/api/models$,POST=^/api/chat/completions$,POST=^/api/message$,POST=^/api/v1/messages$
# Refresh cookie against Keycloak hourly
OAUTH2_PROXY_COOKIE_REFRESH=1h
# Avoid hitting timeout on long tasks (import/export/render)
OAUTH2_PROXY_UPSTREAM_TIMEOUT=300s
# Pin cookie behavior
OAUTH2_PROXY_COOKIE_SAMESITE=lax
OAUTH2_PROXY_COOKIE_CSRF_PER_REQUEST=true
OAUTH2_PROXY_COOKIE_CSRF_PER_REQUEST_LIMIT=5