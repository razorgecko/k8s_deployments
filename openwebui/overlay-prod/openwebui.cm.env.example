WEBUI_URL=https://<domain.example.com>
WEBUI_AUTH_SIGNOUT_REDIRECT_URL=https://<domain.example.com>/auth
# Logout tears down all three sessions:
# Open WebUI cookie -> /oauth2/sign_out (oauth2-proxy cookie) -> Keycloak SSO session
# Do NOT redirect back to the app root after logout to avoid reload loop
# WEBUI_AUTH_SIGNOUT_REDIRECT_URL=https://<domain.example.com>/oauth2/sign_out?rd=https%3A%2F%2F<oauth.example.com>%2Frealms%2F<realm>%2Fprotocol%2Fopenid-connect%2Flogout
ENABLE_OAUTH_SIGNUP=true
OAUTH_MERGE_ACCOUNTS_BY_EMAIL=true
OAUTH_PROVIDER_NAME=<Provider>
OPENID_PROVIDER_URL=https://<oauth.example.com>/realms/<realm>/.well-known/openid-configuration
OAUTH_CLIENT_ID=<client-id>
OAUTH_CODE_CHALLENGE_METHOD=S256
OAUTH_SCOPES=openid email profile
OPENID_REDIRECT_URI=https://<domain.example.com>/oauth/oidc/callback
# Disable password login; allow only OAUTH
ENABLE_LOGIN_FORM=false
ENABLE_PASSWORD_AUTH=false
OAUTH_AUTO_REDIRECT=true